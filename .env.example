# ============================================================
# VDAO MVP — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── EAS (Ethereum Attestation Service) ───────────────────
# These are the deployed contract addresses (already set for Arbitrum Sepolia)
NEXT_PUBLIC_EAS_CONTRACT=0xaEF4103A04090071165F78D45D83A0C0782c2B2a
# These get populated after running: npx tsx scripts/deploy-schemas.ts
NEXT_PUBLIC_SCHEMA_EVALUATION_UID=
NEXT_PUBLIC_SCHEMA_PROXIMITY_UID=
NEXT_PUBLIC_SCHEMA_VALIDATION_UID=

# ── RPC (Arbitrum Sepolia) ────────────────────────────────
# Public RPC (default, can be rate limited)
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# Or use Alchemy/Infura for better reliability:
# NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── WalletConnect ─────────────────────────────────────────
# Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Paymaster (Gasless Attestations via Pimlico) ─────────
# Get your API key at https://dashboard.pimlico.io
# Free tier available for testnets
NEXT_PUBLIC_PIMLICO_API_KEY=

# Bundler RPC (filled automatically from PIMLICO_API_KEY, or set manually)
BUNDLER_RPC_URL=https://api.pimlico.io/v2/arbitrum-sepolia/rpc?apikey=YOUR_PIMLICO_API_KEY

# ── Deploy Scripts (server-side only, never expose to client) ──
DEPLOYER_PRIVATE_KEY=
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# ── Supabase Seed Script ─────────────────────────────────
# Can use NEXT_PUBLIC_SUPABASE_URL or override here
SUPABASE_URL=
